# Keep the build context small and make sure nothing local/secret ever
# reaches the Docker daemon or gets baked into an image layer.

# dependencies (npm ci reinstalls these fresh inside the builder stage)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# build output (the builder stage produces these itself)
.next
out

# vcs / editor / os
.git
.gitignore
.vscode
.idea
.DS_Store
Thumbs.db

# env / secrets — NEVER send these to a Docker build context or image
.env
.env.*
!.env.example

# logs
*.log

# this deploy tooling doesn't need to be IN the image, only used to build it
deploy
Dockerfile
docker-compose.yml
.dockerignore

# docs
*.md
