# Haptica AI landing (famit.in) — deploy-time / build-time environment.
#
# Copy this file to `.env` in THIS directory (landing/.env) so
# `docker compose build` can substitute these values in at Next.js build
# time (see docker-compose.yml -> build.args, Dockerfile -> ARG). These two
# values are PUBLIC — Next.js always inlines any NEXT_PUBLIC_* variable into
# the client-side JS bundle — so there is nothing secret in this file and it
# is safe to keep filled in / committed.

# The live product this marketing site links out to (Login / CTA buttons).
NEXT_PUBLIC_APP_URL=https://haptica.famit.in

# This site's own canonical origin (sitemap.xml, OpenGraph/canonical tags).
SITE_URL=https://famit.in

# -----------------------------------------------------------------------------
# The two lines below are NOT Next.js build variables and do NOT belong in
# this file. They are REAL SECRETS read directly from the process
# environment, or from the repo ROOT .env.local
# (C:\Users\kunal\desktop\cal\.env.local — one level up from landing/, already
# gitignored there, never committed) by the operator scripts in deploy/:
#
#   DO_API_TOKEN   Read by deploy/provision-landing-droplet.py.
#                  DigitalOcean API v2 token (read + write) used to create the
#                  droplet and the DO Cloud Firewall that locks it to
#                  Cloudflare's IP ranges.
#
#   CF_API_TOKEN   Read by deploy/cf-setup.py.
#                  Cloudflare API token (NOT the legacy Global API Key) used to
#                  create the DNS records, set SSL mode, and turn on Bot Fight
#                  Mode / rate-limiting / the managed WAF ruleset. Needs scopes
#                  Zone.DNS Edit + Zone.Zone Settings Edit + Zone.Firewall
#                  Services Edit — see deploy/cloudflare-setup.md if the token
#                  currently on hand doesn't have these (e.g. a Wrangler/
#                  Workers-style token, often prefixed "cfut_").
#
# Never put real token VALUES in this file, in .env, or anywhere under
# landing/ — they belong only in the repo root .env.local.
# -----------------------------------------------------------------------------
